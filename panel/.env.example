# ClawPanel environment config
# Copy to .env and fill in your values

# --- Panel ---
# Admin default: admin / ClawVPN2025 (change after first login)

# --- Corp exit (VLESS Reality) — optional ---
# Leave empty to disable corp exit routing (all traffic goes DIRECT)
CORP_EXIT_ADDRESS=
CORP_EXIT_PORT=
CORP_EXIT_UUID=
CORP_EXIT_PUBKEY=
CORP_EXIT_SNI=yr.no
CORP_EXIT_SHORT_ID=
CORP_EXIT_FINGERPRINT=chrome

# --- TLS certificates ---
CERT_VLESS_FULLCHAIN=/etc/ssl/xray/fullchain.pem
CERT_VLESS_KEY=/etc/ssl/xray/privkey.pem
CERT_HY2_FULLCHAIN=/etc/ssl/xray/fullchain.pem
CERT_HY2_KEY=/etc/ssl/xray/privkey.pem

# --- XDNS finalmask domain ---
XDNS_DOMAIN=t.example.com
