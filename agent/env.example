# Agent environment config
# Copy to /etc/claw-agent/env on each node

PANEL_URL=https://panel.example.com
AGENT_SECRET=your-agent-secret-from-panel-settings
NODE_NAME=NL1
XRAY_HY_BIN=/usr/local/bin/xray-hy
XRAY_HY_CFG=/etc/claw-xray-hy/config.json
XRAY_HY_SERVICE=claw-xray-hy
XRAY_API_PORT=10085
SYNC_INTERVAL=60
